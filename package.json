{
  "name": "hamsterbase-tasks",
  "private": true,
  "version": "99.99.99",
  "type": "module",
  "author": {
    "email": "support@hamsterbase.com",
    "name": "Hamsterbase Team"
  },
  "scripts": {
    "build:coverage": "tsc -b && VITE_COVERAGE=true vite build",
    "lint": "eslint src --no-warn-ignored",
    "check": "tsc -b && npm run lint",
    "format": "prettier -w src",
    "dev:web": "vite --host 0.0.0.0 --port 4000 --strictPort",
    "dev:android": "TAURI_DEV_PORT=4001 vite --host 0.0.0.0 --port 4001 --strictPort",
    "web:dev": "pnpm dev:web",
    "web:build": "vite build",
    "docker:build": "docker build -t hamsterbase-tasks .",
    "server:db": "docker compose up -d postgres",
    "server:api": "set -a; . ./.env; set +a; cd server && go run ./cmd/tasks-server",
    "server:build": "docker compose build tasks",
    "server:up": "docker compose up -d --build",
    "server:stop": "docker compose stop tasks",
    "server:down": "docker compose down",
    "server:restart": "docker compose restart tasks",
    "server:logs": "docker compose logs -f tasks",
    "server:ps": "docker compose ps",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:android:init": "ANDROID_HOME=/opt/homebrew/share/android-commandlinetools ANDROID_NDK_HOME=/opt/homebrew/share/android-commandlinetools/ndk/27.2.12479018 NDK_HOME=/opt/homebrew/share/android-commandlinetools/ndk/27.2.12479018 JAVA_HOME=\"$HOME/.local/share/mise/installs/java/temurin-17\" PATH=\"$HOME/.cargo/bin:/opt/homebrew/share/android-commandlinetools/cmdline-tools/latest/bin:/opt/homebrew/share/android-commandlinetools/platform-tools:$PATH\" tauri android init",
    "tauri:android:dev": "ANDROID_HOME=/opt/homebrew/share/android-commandlinetools ANDROID_NDK_HOME=/opt/homebrew/share/android-commandlinetools/ndk/27.2.12479018 NDK_HOME=/opt/homebrew/share/android-commandlinetools/ndk/27.2.12479018 JAVA_HOME=\"$HOME/.local/share/mise/installs/java/temurin-17\" PATH=\"$HOME/.cargo/bin:/opt/homebrew/share/android-commandlinetools/cmdline-tools/latest/bin:/opt/homebrew/share/android-commandlinetools/platform-tools:$PATH\" tauri android dev --host \"$(ipconfig getifaddr en0)\"",
    "tauri:android:build": "ANDROID_HOME=/opt/homebrew/share/android-commandlinetools ANDROID_NDK_HOME=/opt/homebrew/share/android-commandlinetools/ndk/27.2.12479018 NDK_HOME=/opt/homebrew/share/android-commandlinetools/ndk/27.2.12479018 JAVA_HOME=\"$HOME/.local/share/mise/installs/java/temurin-17\" PATH=\"$HOME/.cargo/bin:/opt/homebrew/share/android-commandlinetools/cmdline-tools/latest/bin:/opt/homebrew/share/android-commandlinetools/platform-tools:$PATH\" tauri android build",
    "cli": "tsx --tsconfig tsconfig.app.json src/cli/index.tsx"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run check"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/lib-storage": "^3.1085.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/crypto-js": "^4.2.2",
    "@types/estree": "^1.0.9",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/test-exclude": "^6.0.2",
    "@typescript/native": "npm:typescript@~7.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "allotment": "^1.20.5",
    "classnames": "^2.5.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.4.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "espree": "^11.2.0",
    "globals": "^17.7.0",
    "ink": "^7.1.0",
    "istanbul-lib-instrument": "^6.0.3",
    "large-small-dynamic-viewport-units-polyfill": "^0.1.1",
    "lint-staged": "^17.0.8",
    "loro-crdt": "^1.13.6",
    "lucide-react": "1.24.0",
    "minimatch": "^10.2.5",
    "nanoid": "^6.0.0",
    "openai": "^6.46.0",
    "prettier": "^3.9.5",
    "rc-textarea": "^1.10.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router": "^8.2.0",
    "react-window": "^2.2.7",
    "rollup": "^4.62.2",
    "rollup-plugin-esbuild": "^6.2.1",
    "rxjs": "^7.8.2",
    "simple-git-hooks": "^2.13.1",
    "source-map": "^0.7.6",
    "string-width": "^8.2.2",
    "swr": "^2.4.2",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@11.11.0",
  "dependencies": {
    "@hamsterbase/foundation": "0.1.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4"
  }
}
