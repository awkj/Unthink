AUTH_TOKEN=replace-with-a-long-random-token
DATABASE_URL=postgres://tasks:change-me@127.0.0.1:5432/tasks?sslmode=disable
CORS_ORIGIN=*
ADDRESS=:8400

POSTGRES_DB=tasks
POSTGRES_USER=tasks
POSTGRES_PASSWORD=change-me
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432

SERVER_BIND=0.0.0.0
SERVER_PORT=8400

# RustFS stores attachment objects. Use long, independently generated secrets.
RUSTFS_IMAGE=rustfs/rustfs:1.0.0-beta.2
RUSTFS_ACCESS_KEY=replace-with-a-rustfs-access-key
RUSTFS_SECRET_KEY=replace-with-a-long-random-secret-key
# Restricted credentials used only by the Tasks server inside the Docker network.
RUSTFS_SERVER_ACCESS_KEY=replace-with-a-server-access-key
RUSTFS_SERVER_SECRET_KEY=replace-with-a-different-long-random-secret-key
RUSTFS_BUCKET=tasks-attachments
RUSTFS_REGION=us-east-1
# The management console defaults to localhost; use an SSH tunnel for remote access.
RUSTFS_CONSOLE_BIND=127.0.0.1
RUSTFS_CONSOLE_PORT=9001
RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS=*
