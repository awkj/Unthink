{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UnThink",
  "version": "0.1.0",
  "identifier": "io.github.awkj.unthink",
  "build": {
    "beforeDevCommand": "pnpm web:dev",
    "devUrl": "http://localhost:4000",
    "beforeBuildCommand": "pnpm web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "UnThink",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#ffffff"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Local-first task manager",
    "android": {
      "minSdkVersion": 24
    }
  }
}
